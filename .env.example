# Clerk (Primary domain app)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
CLERK_SECRET_KEY=sk_live_xxx_or_sk_test_xxx

# Optional: Clerk custom routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk multi-domain / satellites
# Set these only on satellite apps (NOT on primary) or via Vercel env per-domain:
# CLERK_DOMAIN=www.xencolabs.com
# CLERK_IS_SATELLITE=true
# CLERK_PROXY_URL=https://clerk.xencolabs.com

# Neon Postgres
DATABASE_URL=postgres://user:password@ep-xxxxx.neon.tech/dbname?sslmode=require

# Thesys C1 (GenUI) — optional
NEXT_PUBLIC_THESYS_API_KEY=sk_c1_xxx

# Access link generator (/admin/tokens) — required only if issuing gated-document links.
# ACCESS_TOKEN_SECRET signs the magic links; rotating it invalidates every issued link.
# ADMIN_PASSWORD is a second gate on top of Clerk, since public sign-up is enabled.
ACCESS_TOKEN_SECRET=long_random_string_min_32_chars
ADMIN_PASSWORD=choose_a_strong_shared_password

# Base URL used when building magic links (defaults to https://xencolabs.com)
NEXT_PUBLIC_SITE_URL=https://xencolabs.com

# SMTP — powers /api/growth-audit and /api/advisory-briefing notifications.
# If unset, submissions still persist to the database (email is skipped).
SMTP_HOST=mail.xencolabs.com
SMTP_PORT=465
SMTP_USER=notifications@xencolabs.com
SMTP_PASS=your_smtp_password
SMTP_FROM=notifications@xencolabs.com

# Mautic enrollment for /advisory briefing requests (best-effort; OAuth2
# client_credentials against the public instance). Use a NEW Xenco Labs
# credential pair — never ResumeCoach's (one-channel-one-key). Leave unset to
# skip enrollment without affecting Neon capture + email notification.
MAUTIC_URL=https://mautic.xencolabs.com
MAUTIC_OAUTH_TOKEN_URL=https://mautic.xencolabs.com/oauth/v2/token
MAUTIC_OAUTH_CLIENT_ID=xl_oauth_client_id
MAUTIC_OAUTH_CLIENT_SECRET=xl_oauth_client_secret
